#!/usr/bin/env python3
# pylint: disable=invalid-name
import subprocess
import sys
from collections import Counter
from concurrent.futures import ThreadPoolExecutor, as_completed
from typing import Optional


def get_submodule_paths() -> Optional[set[str]]:
    result = subprocess.run(["git", "submodule", "status"],
                            capture_output=True,
                            text=True,
                            check=True)
    if result.returncode != 0:
        return None
    submodules = set()
    for line in result.stdout.splitlines():
        # <indicator>hash path<maybe_space><maybe_other>
        # Skip the indicator and hash
        line = line[len(" ######################################## "):]
        # path<maybe_space><maybe_other>
        submodule = line
        if line.endswith(')'):  # There's an "other"
            parts = line.split(' ')
            submodule = ' '.join(parts[0:-1])
        submodules.add(submodule)

    return submodules


def get_file_authors(file: str) -> Optional[Counter[str]]:
    try:
        result = subprocess.run(
            ["git", "blame", "--line-porcelain", "--", file],
            capture_output=True,
            text=True,
            check=True)
    except UnicodeDecodeError:
        # Binary files are not supported
        return None

    if result.returncode != 0:
        return None
    # <commit_hash> 1 1 3
    # author <author>
    # author-mail <<email>>
    # author-time <time>
    # author-tz <tz>
    # committer <commiter>
    # committer-mail <email>
    # committer-time <time>
    # committer-tz <tz>
    # summary <commit message>
    # filename <filename>
    # <code>
    lines = result.stdout.splitlines()
    authors = [
        line[len("author "):] for line in lines if line.startswith("author ")
    ]
    counter = Counter(authors)
    return counter


def main() -> int:

    # Ensure we are inside a git repository
    try:
        subprocess.run(["git", "rev-parse", "--is-inside-work-tree"],
                       capture_output=True,
                       text=True,
                       check=True)
    except subprocess.CalledProcessError:
        print("Not a git repository.", file=sys.stderr)
        return -3

    submodules = get_submodule_paths()
    if submodules is None:
        return -1

    git_files_proc = subprocess.run(["git", "ls-files"],
                                    capture_output=True,
                                    text=True,
                                    check=True)
    if git_files_proc.returncode != 0:
        return -2

    files = [
        f for f in git_files_proc.stdout.splitlines() if f not in submodules
    ]

    author_counts: Counter[str] = Counter()
    with ThreadPoolExecutor() as executor:
        future_to_file = {
            executor.submit(get_file_authors, f): f
            for f in files
        }
        for future in as_completed(future_to_file):
            counts = future.result()
            if counts:
                author_counts += counts

    for author, count in author_counts.most_common():
        print(author, count)
    return 0


if __name__ == "__main__":
    sys.exit(main())
